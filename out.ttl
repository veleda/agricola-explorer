    <http://veronahe.no/agricola/id> "K115" ;
    rdfs:label "Swing Plough" ;
    def:Card_Text "Twice during the game, when you use the ”Plough 1 Field” action space, you can plough 3 fields instead of 1." ;
    def:Prerequisite "3 Occupations" .

<http://veronahe.no/agricola/K119>    <http://veronahe.no/agricola/affects> <http://veronahe.no/agricola/once_per_round> ;
    <http://veronahe.no/agricola/gains> <http://veronahe.no/agricola/action_space>, <http://veronahe.no/agricola/field> ;
