PREFIX : <http://veronahe.no/agricola/>
PREFIX def: <urn:maplib_default:>

# CQ3: Which cards reference other cards, and what do those referenced cards gain?
# Traverses the :relatedTo edges to find card synergies and combos.

SELECT ?cardName ?refName ?refGain
WHERE {
  ?card :relatedTo ?ref ;
        rdfs:label ?cardName .
  ?ref rdfs:label ?refName .
  OPTIONAL { ?ref :gains ?refGain }
}
ORDER BY ?cardName
LIMIT 20
