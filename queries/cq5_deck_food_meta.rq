PREFIX : <http://veronahe.no/agricola/>
PREFIX def: <urn:maplib_default:>

# CQ5: Which deck has the highest average win ratio for food-gaining cards?
# A meta-level question: if you're drafting for food, which deck should you prefer?

SELECT ?deck (AVG(?winRatio) AS ?avgWin) (COUNT(?card) AS ?cardCount)
WHERE {
  ?card :gains :food ;
        def:Deck ?deck ;
        def:win_ratio ?winRatio .
}
GROUP BY ?deck
ORDER BY DESC(?avgWin)
