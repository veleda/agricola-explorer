PREFIX : <http://veronahe.no/agricola/>
PREFIX def: <urn:maplib_default:>

# CQ1: Which cards gain food AND trigger every round or harvest?
# These are the "food engine" cards — reliable food sources that fire repeatedly.

SELECT ?name ?deck ?winRatio ?text
WHERE {
  ?card :gains :food ;
        :affects ?timing ;
        rdfs:label ?name ;
        def:Deck ?deck ;
        def:win_ratio ?winRatio ;
        def:Card_Text ?text .
  FILTER(?timing IN (:each_round, :harvest, :whenever))
}
ORDER BY DESC(?winRatio)
LIMIT 15
