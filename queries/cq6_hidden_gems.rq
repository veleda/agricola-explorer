PREFIX : <http://veronahe.no/agricola/>
PREFIX def: <urn:maplib_default:>

# CQ6: Which cards have high win ratios but are rarely drafted?
# "Hidden gems" — cards that tournament players overlook but that actually win.
# Filters: win ratio > 45%, play ratio < 15%, ADP > 5 (picked late).

SELECT ?name ?deck ?winRatio ?playRatio ?adp
WHERE {
  ?card rdfs:label ?name ;
        def:Deck ?deck ;
        rdf:type ?typeIRI ;
        def:win_ratio ?winRatio ;
        def:play_ratio ?playRatio ;
        def:ADP ?adp .
  ?typeIRI rdfs:subClassOf :CardCateogry .
  FILTER(?winRatio > 0.45 && ?playRatio < 0.15 && ?adp > 5)
}
ORDER BY DESC(?winRatio)
LIMIT 15
