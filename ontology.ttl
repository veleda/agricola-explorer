@prefix : <http://veronahe.no/agricola/> .

@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:Cost a owl:Class ;
    rdfs:label "Cost"@en .

:Clay a :Cost ;
    rdfs:label "clay"@en .

:Wood a :Cost ;
    rdfs:label "wood"@en .

:Stone a :Cost ;
    rdfs:label "stone"@en .

:Reed a :Cost ;
    rdfs:label "reed"@en .

:CardCateogry a owl:Class .

:Occupation a owl:Class ;
    rdfs:label "Occupation"@en ;
    rdfs:subClassOf :CardCateogry .

:MajorImprovement a owl:Class ;
    rdfs:label "Major improvement"@en ;
    rdfs:subClassOf :CardCateogry .

:MinorImprovement a owl:Class ;
    rdfs:label "Minor improvement"@en ;
    rdfs:subClassOf :CardCateogry .