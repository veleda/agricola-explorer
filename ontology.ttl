# ── Datatype properties (card attributes) ────────────────────────────────────

:id a owl:DatatypeProperty ;
    rdfs:label "card ID"@en ;
    rdfs:range xsd:string .

:players a owl:DatatypeProperty ;
    rdfs:label "minimum players"@en ;
    rdfs:range xsd:string .

:prerequisite a owl:DatatypeProperty ;
    rdfs:label "prerequisite"@en ;
    rdfs:range xsd:string .

:cardText a owl:DatatypeProperty ;
    rdfs:label "card text"@en ;
    rdfs:range xsd:string .

:bonusPoints a owl:DatatypeProperty ;
    rdfs:label "bonus points"@en ;
    rdfs:range xsd:string .

:banned a owl:DatatypeProperty ;
    rdfs:label "banned"@en ;
    rdfs:range xsd:boolean .

:isNo a owl:DatatypeProperty ;
    rdfs:label "in Norwegian deck"@en ;
    rdfs:range xsd:boolean .

# ── Datatype properties (tournament statistics) ──────────────────────────────

:dealt a owl:DatatypeProperty ;
    rdfs:label "times dealt"@en ;
    rdfs:range xsd:double .

:drafted a owl:DatatypeProperty ;
    rdfs:label "times drafted"@en ;
    rdfs:range xsd:double .

:played a owl:DatatypeProperty ;
    rdfs:label "times played"@en ;
    rdfs:range xsd:double .

:won a owl:DatatypeProperty ;
    rdfs:label "times won"@en ;
    rdfs:range xsd:double .

:adp a owl:DatatypeProperty ;
    rdfs:label "average draft position"@en ;
    rdfs:range xsd:double .

:playRatio a owl:DatatypeProperty ;
    rdfs:label "play ratio"@en ;
    rdfs:range xsd:double .

:winRatio a owl:DatatypeProperty ;
    rdfs:label "win ratio"@en ;
    rdfs:range xsd:double .

:pwr a owl:DatatypeProperty ;
    rdfs:label "power rating"@en ;
    rdfs:range xsd:double .

:pwrNoLog a owl:DatatypeProperty ;
    rdfs:label "power rating (no log)"@en ;
    rdfs:range xsd:double .

:pwrNormalized a owl:DatatypeProperty ;
    rdfs:label "power rating normalized"@en ;
    rdfs:range xsd:string .

# ── Object properties ────────────────────────────────────────────────────────

:hasCost a owl:ObjectProperty ;
    rdfs:label "has cost"@en ;
    rdfs:range :CostPermutation .

:gains a owl:ObjectProperty ;
    rdfs:label "gains"@en ;
    rdfs:comment "Resource or effect this card produces."@en .

:affects a owl:ObjectProperty ;
    rdfs:label "affects"@en ;
    rdfs:comment "Game mechanic this card interacts with."@en .

:relatedTo a owl:ObjectProperty ;
    rdfs:label "related to"@en ;
    rdfs:comment "Another card referenced in this card's text."@en .

:costValue a owl:ObjectProperty ;
    rdfs:label "cost value"@en ;
    rdfs:comment "Special cost resource reference."@en .

:deck a owl:ObjectProperty ;
    rdfs:label "deck"@en ;
    rdfs:comment "The deck this card belongs to."@en ;
    rdfs:range :Deck .

:compatibleWith a owl:ObjectProperty ;
    rdfs:label "compatible with"@en ;
    rdfs:comment "Agricola edition this deck is compatible with."@en ;
    rdfs:domain :Deck ;
    rdfs:range :Edition .

:deckCode a owl:DatatypeProperty ;
    rdfs:label "deck code"@en ;
    rdfs:comment "Short letter code identifying this deck."@en ;
    rdfs:range xsd:string .

:description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:range xsd:string .

:year a owl:DatatypeProperty ;
    rdfs:label "year"@en ;
    rdfs:range xsd:integer .

:publisher a owl:DatatypeProperty ;
    rdfs:label "publisher"@en ;
    rdfs:range xsd:string .

# ── Datatype properties (cost permutation resources) ─────────────────────────

:clay a owl:DatatypeProperty ;
    rdfs:label "clay cost"@en ;
    rdfs:range xsd:integer .

:stone a owl:DatatypeProperty ;
    rdfs:label "stone cost"@en ;
    rdfs:range xsd:integer .

:reed a owl:DatatypeProperty ;
    rdfs:label "reed cost"@en ;
    rdfs:range xsd:integer .

:wood a owl:DatatypeProperty ;
    rdfs:label "wood cost"@en ;
    rdfs:range xsd:integer .

:food a owl:DatatypeProperty ;
    rdfs:label "food cost"@en ;
    rdfs:range xsd:integer .

:grain a owl:DatatypeProperty ;
    rdfs:label "grain cost"@en ;
    rdfs:range xsd:integer .

:vegetable a owl:DatatypeProperty ;
    rdfs:label "vegetable cost"@en ;
    rdfs:range xsd:integer .
