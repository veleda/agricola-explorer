@prefix : <http://agricola.veronahe.no/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# ── Ontology declaration ─────────────────────────────────────────────────────

<http://agricola.veronahe.no/> a owl:Ontology ;
    rdfs:label "Agricola Card Ontology"@en ;
    rdfs:comment "Ontology for the Agricola board game card knowledge graph."@en .

# ── Classes ──────────────────────────────────────────────────────────────────

:CardCategory a owl:Class ;
    rdfs:label "Card Category"@en .

:Occupation a owl:Class ;
    rdfs:label "Occupation"@en ;
    rdfs:subClassOf :CardCategory .

:MajorImprovement a owl:Class ;
    rdfs:label "Major Improvement"@en ;
    rdfs:subClassOf :CardCategory .

:MinorImprovement a owl:Class ;
    rdfs:label "Minor Improvement"@en ;
    rdfs:subClassOf :CardCategory .

:Cost a owl:Class ;
    rdfs:label "Cost"@en .

:CostPermutation a owl:Class ;
    rdfs:label "Cost Permutation"@en ;
    rdfs:comment "A unique combination of resources required to play a card."@en .

:Deck a owl:Class ;
    rdfs:label "Deck"@en ;
    rdfs:comment "A named card deck or expansion for Agricola."@en .

:Edition a owl:Class ;
    rdfs:label "Edition"@en ;
    rdfs:comment "A major Agricola game edition."@en .

# ── Edition instances ─────────────────────────────────────────────────────────

:Original a :Edition ;
    rdfs:label "Original Agricola"@en ;
    :year 2007 .

:Revised a :Edition ;
    rdfs:label "Agricola Revised Edition"@en ;
    :year 2016 .

# ── Deck instances ────────────────────────────────────────────────────────────

:deck_E a :Deck ;
    rdfs:label "E Deck"@en ;
    :deckCode "E" ;
    :description "Base game Beginner (Einsteiger) deck. Part of original E/I/K base game decks."@en ;
    :year 2007 ;
    :publisher "Z-Man" ;
    :compatibleWith :Original .

:deck_I a :Deck ;
    rdfs:label "I Deck"@en ;
    :deckCode "I" ;
    :description "Base game Intermediate (Interaktiv) deck. Part of original E/I/K base game decks."@en ;
    :year 2007 ;
    :publisher "Z-Man" ;
    :compatibleWith :Original .

:deck_K a :Deck ;
    rdfs:label "K Deck"@en ;
    :deckCode "K" ;
