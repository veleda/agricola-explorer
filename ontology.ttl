@prefix : <http://veronahe.no/agricola/> .

@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .


:Clay a rdfs:Datatype ;
    rdfs:label "clay"@en ;
    rdfs:isDefinedBy xsd:integer .

:Wood a rdfs:Datatype ;
    rdfs:label "wood"@en ;
    rdfs:isDefinedBy xsd:integer .

:Stone a rdfs:Datatype ;
    rdfs:label "stone"@en ;
    rdfs:isDefinedBy xsd:integer .

:Reed a rdfs:Datatype ;
    rdfs:label "reed"@en ;
    rdfs:isDefinedBy xsd:integer .

:CardCateogry a owl:Class .

:Occupation a owl:Class ;
    rdfs:label "Occupation"@en ;
    rdfs:subClassOf :CardCateogry .

:MajorImprovement a owl:Class ;
    rdfs:label "Major improvement"@en ;
    rdfs:subClassOf :CardCateogry .

:MinorImprovement a owl:Class ;
    rdfs:label "Minor improvement"@en ;
    rdfs:subClassOf :CardCateogry .